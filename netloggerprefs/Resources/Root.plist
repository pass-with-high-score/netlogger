<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>title</key>
	<string>NetLogger</string>
	<key>items</key>
	<array>
		<!-- ======== GENERAL ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>General</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Enable NetLogger</string>
			<key>key</key>
			<string>enabled</string>
			<key>defaults</key>
			<string>com.minh.netlogger</string>
			<key>default</key>
			<false/>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Disable App Caching (No 304)</string>
			<key>key</key>
			<string>noCachingEnabled</string>
			<key>defaults</key>
			<string>com.minh.netlogger</string>
			<key>default</key>
			<false/>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>label</key>
			<string>Enable Socket Capture (TCP/UDP)</string>
			<key>key</key>
			<string>socketCaptureEnabled</string>
			<key>defaults</key>
			<string>com.minh.netlogger</string>
			<key>default</key>
			<false/>
		</dict>

		<!-- ======== APP SELECTION ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>App Selection</string>
			<key>footerText</key>
			<string>Choose which apps to intercept network requests from.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkListCell</string>
			<key>detail</key>
			<string>ATLApplicationListMultiSelectionController</string>
			<key>defaults</key>
			<string>com.minh.netlogger</string>
			<key>key</key>
			<string>selectedApps</string>
			<key>label</key>
			<string>Select Apps to Monitor</string>
			<key>sections</key>
			<array>
				<dict>
					<key>sectionType</key>
					<string>User</string>
				</dict>
				<dict>
					<key>sectionType</key>
					<string>System</string>
				</dict>
			</array>
			<key>useSearchBar</key>
			<true/>
			<key>showIdentifiersAsSubtitle</key>
			<true/>
		</dict>

		<!-- ======== BLACKLIST ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Block Rules</string>
			<key>footerText</key>
			<string>Manage domains to exclude from network logs.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>Blacklisted Domains</string>
			<key>detail</key>
			<string>NLBlacklistController</string>
			<key>isController</key>
			<true/>
		</dict>

		<!-- ======== MITM RULES ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Advanced</string>
			<key>footerText</key>
			<string>Man-in-the-Middle: Modify API responses in real-time.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>MitM Response Rules</string>
			<key>detail</key>
			<string>NLMitmRulesController</string>
			<key>isController</key>
			<true/>
		</dict>

		<!-- ======== LOGS ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Logs</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>Network Analytics</string>
			<key>detail</key>
			<string>NLAnalyticsController</string>
			<key>isController</key>
			<true/>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkCell</string>
			<key>label</key>
			<string>View Network Logs</string>
			<key>detail</key>
			<string>NetLoggerLogViewerController</string>
			<key>isController</key>
			<true/>
		</dict>

		<!-- ======== ABOUT ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>About</string>
			<key>footerText</key>
			<string>NetLogger v0.0.1 - Universal Network Interceptor.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>GitHub / Source Code ⭐️</string>
			<key>action</key>
			<string>openGithub</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>Version</string>
			<key>get</key>
			<string>getVersion:</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>Author</string>
			<key>get</key>
			<string>getAuthor:</string>
		</dict>

		<!-- ======== DANGER ======== -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>Restore Default Settings</string>
			<key>action</key>
			<string>restoreSettings</string>
			<key>alignment</key>
			<integer>2</integer>
		</dict>

	</array>
</dict>
</plist>
